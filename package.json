{
  "name": "mamaworld-tests",
  "version": "1.0.0",
  "description": "Complete Playwright test suite for mamaworld.in",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:all": "playwright test --reporter=html",
    "install:browsers": "playwright install chromium firefox webkit"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "mamaworld"
  ],
  "author": "Test Suite",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "playwright": "^1.59.1"
  }
}
